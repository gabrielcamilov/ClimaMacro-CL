# =============================================================================
# ClimaMacro-CL — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python

# ---------------------------------------------------------------------------
# Entorno virtual
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Variables de entorno (nunca commitear credenciales)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Datos (demasiado pesados para Git; usar DVC o GCS en el futuro)
# ---------------------------------------------------------------------------
data/raw/**/*
data/processed/**/*
data/external/**/*
!data/raw/**/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# ---------------------------------------------------------------------------
# MLflow (artefactos locales)
# ---------------------------------------------------------------------------
mlruns/**/*
!mlruns/.gitkeep

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/**/*
!logs/.gitkeep
*.log

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------------------------------------------------------------------------
# IDEs y editores
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Testing y cobertura
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ---------------------------------------------------------------------------
# mypy
# ---------------------------------------------------------------------------
.mypy_cache/

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
*.env.docker

# ---------------------------------------------------------------------------
# GCP / Azure credentials
# ---------------------------------------------------------------------------
*.json
!pyproject.toml
service-account-*.json
gcp-credentials*.json
