# =============================================================================
# ClimaMacro-CL — Variables de entorno
# Copiar este archivo como .env y completar los valores reales.
# NUNCA commitear el archivo .env con credenciales.
# =============================================================================

# ---------------------------------------------------------------------------
# Banco Central de Chile API
# Registro en: https://si3.bcentral.cl/Siete/
# ---------------------------------------------------------------------------
BCENTRAL_USER=tu_email@ejemplo.com
BCENTRAL_PASS=tu_password_aqui

# ---------------------------------------------------------------------------
# GCP (para deploy en Cloud Run)
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=climamacro-cl
GCP_REGION=us-central1

# ---------------------------------------------------------------------------
# MLflow (tracking server remoto, opcional en fase 1)
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000

# ---------------------------------------------------------------------------
# Entorno de ejecución
# ---------------------------------------------------------------------------
ENVIRONMENT=development   # development | staging | production
LOG_LEVEL=INFO
